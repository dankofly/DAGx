---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import Architecture from '../components/Architecture.astro';
import ProductShowcase from '../components/ProductShowcase.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Features from '../components/Features.astro';
import UseCases from '../components/UseCases.astro';
import Differentiator from '../components/Differentiator.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';

const title = 'DAGx — AI-Workflow Orchestrierung für Agenturen | Hypeakz.io';
const description = 'Steuere deine AI-Agenten wie ein CEO: DAGs, DNA-Snapshots, Score/Fitness und Team-Routing. Early Access jetzt anfragen.';
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://hypeakz.io/#organization",
          "name": "Hypeakz.io",
          "url": "https://hypeakz.io",
          "contactPoint": {
            "@type": "ContactPoint",
            "email": "contact@hypeakz.io",
            "contactType": "sales"
          }
        },
        {
          "@type": "SoftwareApplication",
          "@id": "https://dagx.agency/#software",
          "name": "DAGx",
          "description": "AI-Workflow Orchestrierung für Agenturen: DAG Workflows, DNA Snapshots, Score/Fitness, Team-Routing und Energy Policies für reproduzierbare AI-Ausführung.",
          "applicationCategory": "DeveloperApplication",
          "applicationSubCategory": "AI Orchestration",
          "operatingSystem": "Web",
          "url": "https://dagx.agency",
          "author": {
            "@id": "https://hypeakz.io/#organization"
          },
          "offers": {
            "@type": "Offer",
            "availability": "https://schema.org/PreOrder",
            "price": "0",
            "priceCurrency": "EUR",
            "description": "Early Access — kostenlos"
          },
          "featureList": [
            "DAG Layer mit Dependencies und Graph View",
            "DNA Compiler (.toon) mit Snapshots und Run-Pinning",
            "Score/Fitness Loop mit J-Funktion",
            "Compare Engine (Base vs Candidate)",
            "Energy Controller mit Limits und Enforcement",
            "Skill Registry mit Routing Advisor",
            "Experiments Runner (Sandbox)",
            "Multi-Project Isolation mit Scoped Storage"
          ]
        }
      ]
    })} />
  </Fragment>

  <Header />
  <main>
    <Hero />
    <Problem />
    <Architecture />
    <ProductShowcase />
    <HowItWorks />
    <Features />
    <UseCases />
    <Differentiator />
    <Pricing />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>
