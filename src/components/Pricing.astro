---
import Card from './Card.astro';
import Badge from './Badge.astro';

const tiers = [
  {
    name: 'Starter',
    description: 'Einzelprojekt mit Core DAG, DNA Snapshots und Score-Tracking.',
    features: ['1 Projekt', 'DAG Layer', 'DNA Snapshots', 'Score/Fitness', 'Energy Monitoring'],
    highlighted: false,
  },
  {
    name: 'Pro',
    description: 'Experiments, Routing Advisor und Compare Engine für datenbasierte Optimierung.',
    features: ['Alles aus Starter', 'Experiments Runner', 'Compare Engine', 'Routing Advisor', 'Approval Workflows'],
    highlighted: true,
  },
  {
    name: 'Agency',
    description: 'Multi-Projekt, Team-Management, Deliveries und vollständige Governance.',
    features: ['Alles aus Pro', 'Multi-Project Isolation', 'Team-Management', 'Delivery Pipeline', 'Custom Policies'],
    highlighted: false,
  },
];
---

<section id="pricing" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="animate-fade-in-up mx-auto max-w-3xl text-center">
      <Badge text="Pricing" variant="accent" />
      <h2 class="mt-4 text-2xl font-semibold tracking-tight text-slate-100 md:text-3xl">
        Flexibel nach Bedarf
      </h2>
      <p class="mt-4 text-base text-slate-400">
        Preise werden mit dem Launch bekanntgegeben. Sichere dir jetzt Early Access.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {tiers.map((tier) => (
        <div class:list={[
          'rounded-2xl border p-6 md:p-8 transition-colors',
          tier.highlighted
            ? 'border-indigo-500/40 bg-indigo-500/5'
            : 'border-slate-700/40 bg-slate-900 hover:border-slate-600/60',
        ]}>
          <h3 class="text-lg font-semibold text-slate-100">{tier.name}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-400">{tier.description}</p>
          <ul class="mt-6 space-y-3">
            {tier.features.map((feature) => (
              <li class="flex items-center gap-2 text-sm text-slate-300">
                <svg class="h-4 w-4 shrink-0 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
          <a
            href="#early-access"
            class:list={[
              'mt-8 block rounded-lg py-2.5 text-center text-sm font-medium transition-opacity hover:opacity-90',
              tier.highlighted
                ? 'bg-gradient-to-r from-indigo-500 to-violet-500 text-white'
                : 'border border-slate-700/40 text-slate-300 hover:border-slate-600/60',
            ]}
          >
            Early Access anfragen
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
