---
import Logo from './Logo.astro';

const navLinks = [
  { label: 'Produkt', href: '#problem' },
  { label: 'Architektur', href: '#architektur' },
  { label: 'Features', href: '#features' },
  { label: 'Use Cases', href: '#use-cases' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'FAQ', href: '#faq' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-slate-700/40 bg-slate-950/70 backdrop-blur-2xl">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-2">
      <Logo size="sm" />
    </a>

    <ul class="hidden items-center gap-6 md:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm text-slate-400 transition-colors hover:text-slate-100"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="hidden md:block">
      <a
        href="#early-access"
        class="inline-flex items-center rounded-lg bg-gradient-to-r from-indigo-500 to-violet-500 px-4 py-2 text-sm font-medium text-white transition-opacity hover:opacity-90"
      >
        Early Access anfragen
      </a>
    </div>

    <button
      id="mobile-menu-toggle"
      class="flex items-center justify-center md:hidden"
      aria-label="Menü öffnen"
      aria-expanded="false"
    >
      <svg class="h-6 w-6 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-slate-700/40 bg-slate-950/95 backdrop-blur-xl md:hidden">
    <ul class="flex flex-col gap-1 px-6 py-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-nav-link block rounded-lg px-3 py-2.5 text-sm text-slate-300 transition-colors hover:bg-slate-800 hover:text-slate-100"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="mt-2">
        <a
          href="#early-access"
          class="mobile-nav-link block rounded-lg bg-gradient-to-r from-indigo-500 to-violet-500 px-3 py-2.5 text-center text-sm font-medium text-white"
        >
          Early Access anfragen
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
    if (icon) {
      icon.setAttribute('d', isOpen
        ? 'M4 6h16M4 12h16M4 18h16'
        : 'M6 18L18 6M6 6l12 12'
      );
    }
  });

  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      if (icon) icon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    });
  });
</script>
