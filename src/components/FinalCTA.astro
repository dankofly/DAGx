---
import Badge from './Badge.astro';
---

<div class="section-glow-divider mx-auto max-w-4xl"></div>
<section id="early-access" class="relative py-20 md:py-28">
  <div class="pointer-events-none absolute inset-0 flex items-center justify-center">
    <div class="h-[300px] w-[400px] rounded-full bg-indigo-500/5 blur-3xl"></div>
  </div>
  <div class="relative mx-auto max-w-6xl px-6">
    <div class="animate-fade-in-up mx-auto max-w-3xl text-center">

      <Badge text="Ready to start?" variant="accent" />

      <h2 class="mt-4 text-2xl font-semibold tracking-tight text-slate-100 md:text-3xl">
        Steuere deine AI-Agenten wie ein CEO — nicht wie ein Prompter.
      </h2>
      <p class="mt-4 text-base text-slate-400 md:text-lg">
        DAGx macht OpenClaw reproduzierbar, messbar und effizient steuerbar.
      </p>

      <!-- Email Form -->
      <form
        name="early-access"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="cta-form mt-8 mx-auto max-w-md"
        id="cta-form"
      >
        <input type="hidden" name="form-name" value="early-access" />
        <p class="hidden">
          <label>Nicht ausfüllen: <input name="bot-field" /></label>
        </p>
        <div class="flex flex-col gap-3 sm:flex-row">
          <input
            type="email"
            name="email"
            required
            placeholder="deine@email.com"
            autocomplete="email"
            class="flex-1 rounded-lg border border-slate-700/50 bg-slate-900/60 px-4 py-3 text-sm text-slate-100 placeholder-slate-500 backdrop-blur-sm transition-all focus:border-indigo-500/50 focus:outline-none focus:ring-2 focus:ring-indigo-500/20"
          />
          <button
            type="submit"
            class="btn-shimmer inline-flex items-center justify-center rounded-lg bg-gradient-to-r from-indigo-500 to-violet-500 px-6 py-3 text-sm font-medium text-white transition-opacity hover:opacity-90 cursor-pointer whitespace-nowrap"
          >
            Early Access anfragen
          </button>
        </div>
        <p class="cta-form-success mt-3 hidden text-sm text-green-400">
          Danke! Wir melden uns bei dir.
        </p>
      </form>

      <!-- Trust signals -->
      <div class="mt-10 flex flex-wrap items-center justify-center gap-8 text-sm text-slate-500">
        <div class="flex items-center gap-2">
          <svg class="h-4 w-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span>Kostenloser Early Access</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="h-4 w-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span>Kein Kreditkarte nötig</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="h-4 w-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span>DSGVO-konform</span>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const ctaForm = document.getElementById('cta-form') as HTMLFormElement;
  if (ctaForm) {
    ctaForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = ctaForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      const successMsg = ctaForm.querySelector('.cta-form-success') as HTMLElement;
      const originalText = btn.textContent;

      btn.disabled = true;
      btn.textContent = 'Wird gesendet...';

      try {
        const data = new FormData(ctaForm);
        await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(data as any).toString(),
        });
        ctaForm.reset();
        successMsg.classList.remove('hidden');
        btn.textContent = 'Gesendet!';
        setTimeout(() => {
          successMsg.classList.add('hidden');
          btn.textContent = originalText;
          btn.disabled = false;
        }, 4000);
      } catch {
        btn.textContent = originalText;
        btn.disabled = false;
      }
    });
  }
</script>
