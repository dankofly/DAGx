---
import Badge from './Badge.astro';
---

<section class="relative overflow-hidden pt-32 pb-20 md:pt-40 md:pb-28">
  <div class="mx-auto grid max-w-6xl gap-12 px-6 md:grid-cols-2 md:items-center">
    <div class="animate-fade-in-up">
      <Badge text="Open Beta — Q3 2026" variant="accent" />
      <h1 class="mt-6 text-4xl font-semibold tracking-tight text-slate-100 md:text-6xl">
        DAGx: Der Orchestrierungs-Layer für OpenClaw.
      </h1>
      <p class="mt-6 text-base leading-relaxed text-slate-300 md:text-lg">
        OpenClaw führt aus. DAGx steuert, versioniert und optimiert Workflows mit DAG, DNA und messbarer Governance.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="#early-access"
          class="inline-flex items-center rounded-lg bg-gradient-to-r from-indigo-500 to-violet-500 px-6 py-3 text-sm font-medium text-white transition-opacity hover:opacity-90"
        >
          Early Access anfragen
        </a>
        <a
          href="#architektur"
          class="inline-flex items-center rounded-lg border border-slate-700/40 bg-slate-900 px-6 py-3 text-sm font-medium text-slate-300 transition-colors hover:border-slate-600/60 hover:text-slate-100"
        >
          Architektur ansehen
        </a>
      </div>
    </div>

    <div class="animate-fade-in-up animate-delay-200 flex justify-center">
      <svg viewBox="0 0 400 340" fill="none" class="w-full max-w-md" aria-label="DAGx Architektur-Diagramm: DAGx Control Layer über OpenClaw Execution Engine">
        <!-- OpenClaw Execution Engine -->
        <rect x="40" y="200" width="320" height="100" rx="16" fill="#0f2862" stroke="#4f5f76" stroke-width="1.5"/>
        <text x="200" y="238" text-anchor="middle" fill="#b3bfce" font-size="11" font-weight="500">OPENCLAW</text>
        <text x="200" y="256" text-anchor="middle" fill="#4f5f76" font-size="10">Execution Engine</text>

        <!-- Engine Nodes -->
        <rect x="70" y="268" width="60" height="20" rx="4" fill="#091f36" stroke="#4f5f76" stroke-width="1"/>
        <text x="100" y="282" text-anchor="middle" fill="#4f5f76" font-size="8">Sessions</text>
        <rect x="145" y="268" width="50" height="20" rx="4" fill="#091f36" stroke="#4f5f76" stroke-width="1"/>
        <text x="170" y="282" text-anchor="middle" fill="#4f5f76" font-size="8">Tools</text>
        <rect x="210" y="268" width="60" height="20" rx="4" fill="#091f36" stroke="#4f5f76" stroke-width="1"/>
        <text x="240" y="282" text-anchor="middle" fill="#4f5f76" font-size="8">Runtime</text>
        <rect x="285" y="268" width="55" height="20" rx="4" fill="#091f36" stroke="#4f5f76" stroke-width="1"/>
        <text x="312.5" y="282" text-anchor="middle" fill="#4f5f76" font-size="8">Agents</text>

        <!-- DAGx Control Layer -->
        <rect x="40" y="40" width="320" height="130" rx="16" fill="#091f36" stroke="#9e363a" stroke-width="1.5"/>
        <text x="200" y="72" text-anchor="middle" fill="#d47275" font-size="11" font-weight="600">DAGx</text>
        <text x="200" y="88" text-anchor="middle" fill="#bf4f53" font-size="10">Control Layer</text>

        <!-- DAG Nodes -->
        <circle cx="90" cy="125" r="14" fill="#2a1015" stroke="#9e363a" stroke-width="1.5"/>
        <text x="90" y="129" text-anchor="middle" fill="#d47275" font-size="8">DAG</text>
        <circle cx="155" cy="125" r="14" fill="#2a1015" stroke="#9e363a" stroke-width="1.5"/>
        <text x="155" y="129" text-anchor="middle" fill="#d47275" font-size="8">DNA</text>
        <circle cx="220" cy="125" r="14" fill="#2a1015" stroke="#9e363a" stroke-width="1.5"/>
        <text x="220" y="129" text-anchor="middle" fill="#d47275" font-size="8">Score</text>
        <circle cx="285" cy="125" r="14" fill="#2a1015" stroke="#9e363a" stroke-width="1.5"/>
        <text x="285" y="129" text-anchor="middle" fill="#d47275" font-size="8">Exp</text>

        <!-- Edges between DAG nodes -->
        <line x1="104" y1="125" x2="141" y2="125" stroke="#852d30" stroke-width="1" stroke-dasharray="4 3"/>
        <line x1="169" y1="125" x2="206" y2="125" stroke="#852d30" stroke-width="1" stroke-dasharray="4 3"/>
        <line x1="234" y1="125" x2="271" y2="125" stroke="#852d30" stroke-width="1" stroke-dasharray="4 3"/>

        <!-- Connection arrows -->
        <line x1="200" y1="170" x2="200" y2="200" stroke="#9e363a" stroke-width="1.5" stroke-dasharray="6 4"/>
        <polygon points="194,196 200,206 206,196" fill="#9e363a"/>

        <!-- Side labels -->
        <text x="200" y="188" text-anchor="middle" fill="#852d30" font-size="8" font-weight="500">orchestrates</text>
      </svg>
    </div>
  </div>
</section>
