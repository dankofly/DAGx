---
import Card from './Card.astro';
import Badge from './Badge.astro';

const useCases = [
  {
    title: 'SEO Production System',
    description: 'Audit → Brief → Content → Compare. Reproduzierbare SEO-Pipelines mit Quality Gates, Score-basierter Content-Bewertung und automatischer Delivery.',
    tags: ['Audit', 'Content Pipeline', 'Compare', 'Delivery'],
  },
  {
    title: 'Agency Ops',
    description: 'Teams, Skills, Approvals und Deliveries orchestriert. CEO-Dashboard mit Echtzeit-Überblick über alle Projekte, Agenten und Kosten.',
    tags: ['Teams', 'Approvals', 'Routing', 'Cost Control'],
  },
  {
    title: 'Product Teams',
    description: 'Experiments für Feature-Varianten, Governance über Entscheidungspfade und Budget-Enforcement pro Sprint. Messbar statt meinungsbasiert.',
    tags: ['Experiments', 'Governance', 'Budgets', 'Fitness'],
  },
];
---

<section id="use-cases" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="animate-fade-in-up mx-auto max-w-3xl text-center">
      <Badge text="Use Cases" variant="accent" />
      <h2 class="mt-4 text-2xl font-semibold tracking-tight text-slate-100 md:text-3xl">
        Gebaut für Teams, die AI produktiv einsetzen
      </h2>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {useCases.map((useCase) => (
        <Card>
          <h3 class="text-base font-semibold text-slate-100 md:text-lg">{useCase.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-400">{useCase.description}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {useCase.tags.map((tag) => (
              <span class="rounded-md bg-slate-800 px-2.5 py-1 text-xs text-slate-400">{tag}</span>
            ))}
          </div>
        </Card>
      ))}
    </div>
  </div>
</section>
