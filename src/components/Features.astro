---
import Card from './Card.astro';
import Badge from './Badge.astro';

const features = [
  {
    title: 'DAG Layer',
    description: 'Explizite Dependencies als gerichteter azyklischer Graph. Visuelle Graph-Ansicht, Smoke Test und deterministische Execution Order.',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    title: 'DNA Compiler (.toon)',
    description: 'Versionierte Snapshots von Agent-Konfigurationen, Skills und Policies. Pinbar pro Run für vollständige Reproduzierbarkeit.',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  },
  {
    title: 'Score/Fitness Loop',
    description: 'J-Funktion bewertet jeden Run quantitativ: J = 100 − (Token-Kosten) − (Dauer) − (Fehlerrate). Fitness aggregiert über Zeitreihe.',
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  },
  {
    title: 'Compare Engine',
    description: 'Base vs Candidate Vergleich auf Run- und DNA-Level. Entscheidungen werden datenbasiert getroffen, nicht per Bauchgefühl.',
    icon: 'M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4',
  },
  {
    title: 'Energy Controller',
    description: 'Budget-Limits und Energy-Policies pro Projekt, Team und Agent. Enforcement verhindert unkontrollierte Token-Ausgaben.',
    icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Skill Registry & Routing',
    description: 'Zentrale Verwaltung aller Skills mit Fitness-Scores. Routing Advisor weist Tasks automatisch dem fähigsten Agent zu.',
    icon: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10',
  },
  {
    title: 'Experiments Runner',
    description: 'A/B-Tests für Agent-Konfigurationen und Workflows im Sandbox-Modus. Vergleiche Varianten bevor du produktiv gehst.',
    icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
  },
  {
    title: 'Multi-Project Isolation',
    description: 'Project-scoped Storage, getrennte Fitness-Werte und unabhängige Policies. Kein Projekt beeinflusst ein anderes.',
    icon: 'M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4',
  },
];
---

<section id="features" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="animate-fade-in-up mx-auto max-w-3xl text-center">
      <Badge text="Core Features" variant="accent" />
      <h2 class="mt-4 text-2xl font-semibold tracking-tight text-slate-100 md:text-3xl">
        Alles, was OpenClaw zur Steuerung braucht
      </h2>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {features.map((feature) => (
        <Card>
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-500/10">
            <svg class="h-5 w-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-100 md:text-lg">{feature.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-400">{feature.description}</p>
        </Card>
      ))}
    </div>
  </div>
</section>
